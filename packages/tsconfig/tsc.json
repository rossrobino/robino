{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./check.json",
	"compilerOptions": {
		"rootDir": "${configDir}/src",
		"noEmit": false
	},
	"exclude": [
		"${configDir}/**/*.test.*",
		"${configDir}/*.js",
		"${configDir}/*.ts",
		"${configDir}/node_modules",
		"${configDir}/dist"
	]
}
